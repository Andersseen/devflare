{
  "name": "dev-auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/dev-auth/src",
  "tags": ["scope:backend", "type:service"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/dev-auth"],
      "options": {
        "command": "wrangler deploy --dry-run --outdir=dist/apps/dev-auth",
        "cwd": "apps/dev-auth"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "wrangler dev --local",
        "cwd": "apps/dev-auth"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler deploy",
        "cwd": "apps/dev-auth"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.app.json",
        "cwd": "apps/dev-auth"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "config": "apps/dev-auth/vitest.config.ts"
      }
    }
  }
}
