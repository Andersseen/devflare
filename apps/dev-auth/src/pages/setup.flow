<div and-layout="vertical gap:lg" style="width:100%;max-width:720px;">

  <!-- Header -->
  <div and-layout="horizontal justify:center align:center gap:sm">
    <and-icon name="settings" size="24"></and-icon>
    <span and-text="h5 weight:bold color:foreground">DevFlare Auth Setup</span>
  </div>

  <!-- Stepper indicator -->
  <div id="stepper" and-layout="horizontal justify:between align:center gap:sm" style="padding:0.5rem 0;">
    <div class="step-dot active" data-step="1" and-layout="vertical align:center gap:xs">
      <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:hsl(var(--primary));color:hsl(var(--primary-foreground));font-weight:600;">1</div>
      <span and-text="p-xs color:foreground">Intro</span>
    </div>
    <div style="flex:1;height:2px;background:hsl(var(--border));"></div>
    <div class="step-dot" data-step="2" and-layout="vertical align:center gap:xs">
      <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:hsl(var(--muted));color:hsl(var(--muted-foreground));font-weight:600;">2</div>
      <span and-text="p-xs color:muted">Account</span>
    </div>
    <div style="flex:1;height:2px;background:hsl(var(--border));"></div>
    <div class="step-dot" data-step="3" and-layout="vertical align:center gap:xs">
      <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:hsl(var(--muted));color:hsl(var(--muted-foreground));font-weight:600;">3</div>
      <span and-text="p-xs color:muted">D1 DB</span>
    </div>
    <div style="flex:1;height:2px;background:hsl(var(--border));"></div>
    <div class="step-dot" data-step="4" and-layout="vertical align:center gap:xs">
      <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:hsl(var(--muted));color:hsl(var(--muted-foreground));font-weight:600;">4</div>
      <span and-text="p-xs color:muted">Config</span>
    </div>
    <div style="flex:1;height:2px;background:hsl(var(--border));"></div>
    <div class="step-dot" data-step="5" and-layout="vertical align:center gap:xs">
      <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:hsl(var(--muted));color:hsl(var(--muted-foreground));font-weight:600;">5</div>
      <span and-text="p-xs color:muted">Deploy</span>
    </div>
  </div>

  <!-- Step 1: Intro -->
  <div id="step-1" class="step-panel" and-layout="vertical gap:md">
    <and-card variant="default" padded and-layout="vertical gap:md">
      <h2 and-text="h4 align:center color:foreground">Self-host your auth service</h2>
      <p and-text="p align:center color:muted">
        This wizard will guide you through deploying your own instance of DevFlare Auth
        on Cloudflare Workers + D1 (free tier).
      </p>
      <div and-layout="vertical gap:xs">
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="check" size="16" color="hsl(var(--success))"></and-icon>
          <span and-text="p-sm color:foreground">Free Cloudflare account</span>
        </div>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="check" size="16" color="hsl(var(--success))"></and-icon>
          <span and-text="p-sm color:foreground">Wrangler CLI installed</span>
        </div>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="check" size="16" color="hsl(var(--success))"></and-icon>
          <span and-text="p-sm color:foreground">Node.js 18+</span>
        </div>
      </div>
      <and-button id="btn-step-1" variant="default" style="width:100%;">
        Start Setup
        <and-icon slot="end" name="arrow-right" size="16"></and-icon>
      </and-button>
    </and-card>
  </div>

  <!-- Step 2: Account -->
  <div id="step-2" class="step-panel" style="display:none;" and-layout="vertical gap:md">
    <and-card variant="default" padded and-layout="vertical gap:md">
      <h2 and-text="h4 color:foreground">Cloudflare Account</h2>
      <p and-text="p-sm color:muted">You need a Cloudflare account and an API token with D1 edit permissions.</p>

      <div and-layout="vertical gap:xs">
        <label and-text="p-xs color:foreground weight:medium">Account ID</label>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="user" size="16" color="hsl(var(--muted-foreground))"></and-icon>
          <and-input id="account-id" data-field="accountId" placeholder="Your Cloudflare Account ID" style="flex:1"></and-input>
        </div>
        <p and-text="p-xs color:muted">Found in the right sidebar of your Cloudflare dashboard.</p>
      </div>

      <div and-layout="vertical gap:xs">
        <label and-text="p-xs color:foreground weight:medium">API Token</label>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="lock" size="16" color="hsl(var(--muted-foreground))"></and-icon>
          <and-input id="api-token" data-field="apiToken" type="password" placeholder="Cloudflare API Token" style="flex:1"></and-input>
        </div>
        <p and-text="p-xs color:muted">
          Create one at <a href="https://dash.cloudflare.com/profile/api-tokens" target="_blank" rel="noopener">dash.cloudflare.com/profile/api-tokens</a>
          with <code>Cloudflare D1:Edit</code> permission.
        </p>
      </div>

      <div and-layout="horizontal gap:sm">
        <and-button id="btn-back-2" variant="outline">Back</and-button>
        <and-button id="btn-step-2" variant="default" style="flex:1;">
          Next
          <and-icon slot="end" name="arrow-right" size="16"></and-icon>
        </and-button>
      </div>
    </and-card>
  </div>

  <!-- Step 3: D1 Database -->
  <div id="step-3" class="step-panel" style="display:none;" and-layout="vertical gap:md">
    <and-card variant="default" padded and-layout="vertical gap:md">
      <h2 and-text="h4 color:foreground">Create D1 Database</h2>
      <p and-text="p-sm color:muted">Choose how you want to create your D1 database.</p>

      <div and-layout="vertical gap:xs">
        <label and-text="p-xs color:foreground weight:medium">Database Name</label>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="box" size="16" color="hsl(var(--muted-foreground))"></and-icon>
          <and-input id="db-name" data-field="dbName" value="dev-auth-db" style="flex:1"></and-input>
        </div>
      </div>

      <div and-layout="horizontal gap:sm">
        <and-button id="btn-create-d1" variant="default" style="flex:1;">
          <and-icon slot="start" name="plus" size="16"></and-icon>
          Auto-create D1
        </and-button>
      </div>

      <div and-layout="vertical gap:xs">
        <p and-text="p-sm align:center color:muted">— or manually —</p>
        <code and-text="p-xs" style="display:block;padding:0.75rem;background:hsl(var(--muted));border-radius:0.375rem;overflow-x:auto;">
          wrangler d1 create dev-auth-db
        </code>
      </div>

      <div id="d1-result" style="display:none;" and-layout="vertical gap:xs"></div>

      <div and-layout="horizontal gap:sm">
        <and-button id="btn-back-3" variant="outline">Back</and-button>
        <and-button id="btn-step-3" variant="default" style="flex:1;" disabled>
          Next
          <and-icon slot="end" name="arrow-right" size="16"></and-icon>
        </and-button>
      </div>
    </and-card>
  </div>

  <!-- Step 4: Generate wrangler.toml -->
  <div id="step-4" class="step-panel" style="display:none;" and-layout="vertical gap:md">
    <and-card variant="default" padded and-layout="vertical gap:md">
      <h2 and-text="h4 color:foreground">Generate Config</h2>
      <p and-text="p-sm color:muted">Download your pre-configured <code>wrangler.toml</code> file.</p>

      <div and-layout="vertical gap:xs">
        <label and-text="p-xs color:foreground weight:medium">Worker Name</label>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="box" size="16" color="hsl(var(--muted-foreground))"></and-icon>
          <and-input id="worker-name" data-field="workerName" value="my-dev-auth" style="flex:1"></and-input>
        </div>
      </div>

      <div and-layout="vertical gap:xs">
        <label and-text="p-xs color:foreground weight:medium">Base URL (production)</label>
        <div and-layout="horizontal gap:sm align:center">
          <and-icon name="external-link" size="16" color="hsl(var(--muted-foreground))"></and-icon>
          <and-input id="base-url" data-field="baseUrl" value="https://my-dev-auth.YOUR_SUBDOMAIN.workers.dev" style="flex:1"></and-input>
        </div>
      </div>

      <div and-layout="horizontal gap:sm">
        <and-button id="btn-back-4" variant="outline">Back</and-button>
        <and-button id="btn-download" variant="default" style="flex:1;">
          <and-icon slot="start" name="download" size="16"></and-icon>
          Download wrangler.toml
        </and-button>
      </div>

      <div id="download-preview" style="display:none;" and-layout="vertical gap:xs"></div>
    </and-card>
  </div>

  <!-- Step 5: Deploy -->
  <div id="step-5" class="step-panel" style="display:none;" and-layout="vertical gap:md">
    <and-card variant="default" padded and-layout="vertical gap:md">
      <h2 and-text="h4 align:center color:foreground">Ready to Deploy</h2>
      <p and-text="p align:center color:muted">Follow these final steps to deploy your auth service.</p>

      <div and-layout="vertical gap:xs">
        <p and-text="p-sm color:foreground weight:medium">1. Place wrangler.toml in your project root</p>
        <code and-text="p-xs" style="display:block;padding:0.75rem;background:hsl(var(--muted));border-radius:0.375rem;overflow-x:auto;">
          mv ~/Downloads/wrangler.toml apps/dev-auth/wrangler.toml
        </code>
      </div>

      <div and-layout="vertical gap:xs">
        <p and-text="p-sm color:foreground weight:medium">2. Set your auth secret</p>
        <code and-text="p-xs" style="display:block;padding:0.75rem;background:hsl(var(--muted));border-radius:0.375rem;overflow-x:auto;">
          cd apps/dev-auth && wrangler secret put BETTER_AUTH_SECRET
        </code>
      </div>

      <div and-layout="vertical gap:xs">
        <p and-text="p-sm color:foreground weight:medium">3. Apply D1 migrations</p>
        <code and-text="p-xs" style="display:block;padding:0.75rem;background:hsl(var(--muted));border-radius:0.375rem;overflow-x:auto;">
          wrangler d1 migrations apply dev-auth-db --remote
        </code>
      </div>

      <div and-layout="vertical gap:xs">
        <p and-text="p-sm color:foreground weight:medium">4. Deploy</p>
        <code and-text="p-xs" style="display:block;padding:0.75rem;background:hsl(var(--muted));border-radius:0.375rem;overflow-x:auto;">
          wrangler deploy
        </code>
      </div>

      <div and-layout="horizontal gap:sm">
        <and-button id="btn-back-5" variant="outline">Back</and-button>
        <and-button onclick="window.location.href='/login'" variant="default" style="flex:1;">
          Go to Login
        </and-button>
      </div>
    </and-card>
  </div>

</div>

<script>
  (function() {
    let currentStep = 1;
    const totalSteps = 5;
    const values = {};
    let d1Data = null;

    // Capture input values
    document.querySelectorAll('and-input[data-field]').forEach(function(input) {
      input.addEventListener('andInput', function(e) {
        values[input.dataset.field] = e.detail;
      });
    });

    function showStep(n) {
      for (let i = 1; i <= totalSteps; i++) {
        document.getElementById('step-' + i).style.display = i === n ? '' : 'none';
      }
      // Update stepper dots
      document.querySelectorAll('.step-dot').forEach(function(dot) {
        const stepNum = parseInt(dot.dataset.step, 10);
        const circle = dot.querySelector('div');
        const label = dot.querySelector('span');
        if (stepNum <= n) {
          circle.style.background = 'hsl(var(--primary))';
          circle.style.color = 'hsl(var(--primary-foreground))';
          label.setAttribute('and-text', 'p-xs color:foreground');
        } else {
          circle.style.background = 'hsl(var(--muted))';
          circle.style.color = 'hsl(var(--muted-foreground))';
          label.setAttribute('and-text', 'p-xs color:muted');
        }
      });
      currentStep = n;
    }

    // Navigation buttons
    document.getElementById('btn-step-1').addEventListener('click', function() { showStep(2); });
    document.getElementById('btn-step-2').addEventListener('click', function() { showStep(3); });
    document.getElementById('btn-step-3').addEventListener('click', function() { showStep(4); });
    document.getElementById('btn-back-2').addEventListener('click', function() { showStep(1); });
    document.getElementById('btn-back-3').addEventListener('click', function() { showStep(2); });
    document.getElementById('btn-back-4').addEventListener('click', function() { showStep(3); });
    document.getElementById('btn-back-5').addEventListener('click', function() { showStep(4); });

    // Auto-create D1
    document.getElementById('btn-create-d1').addEventListener('click', async function() {
      const btn = document.getElementById('btn-create-d1');
      const toaster = document.getElementById('toaster');
      const accountId = values.accountId || '';
      const apiToken = values.apiToken || '';
      const dbName = values.dbName || 'dev-auth-db';

      if (!accountId || !apiToken) {
        toaster.present('Please enter Account ID and API Token first', 'destructive');
        return;
      }

      btn.loading = true;

      try {
        const res = await fetch('/api/setup/d1', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ accountId, apiToken, dbName })
        });

        const data = await res.json();

        if (!res.ok || !data.success) {
          throw new Error(data.error || 'Failed to create D1 database');
        }

        d1Data = data.result;
        values.databaseId = d1Data.uuid;
        values.databaseName = d1Data.name;

        const resultDiv = document.getElementById('d1-result');
        resultDiv.style.display = '';
        resultDiv.innerHTML = '<p and-text="p-sm color:success">Database created: <strong>' + escapeHtml(d1Data.name) + '</strong> (ID: ' + escapeHtml(d1Data.uuid.substring(0,8)) + '...)</p>';

        document.getElementById('btn-step-3').disabled = false;
        toaster.present('D1 database created successfully', 'success');
      } catch (err) {
        toaster.present(err.message || 'Failed to create D1. Try manual creation.', 'destructive');
      } finally {
        btn.loading = false;
      }
    });

    // Download wrangler.toml
    document.getElementById('btn-download').addEventListener('click', function() {
      const workerName = values.workerName || 'my-dev-auth';
      const baseUrl = values.baseUrl || 'https://' + workerName + '.workers.dev';
      const dbName = values.databaseName || values.dbName || 'dev-auth-db';
      const dbId = values.databaseId || 'YOUR_DATABASE_ID';

      const toml = 'name = "' + workerName + '"\\n' +
        'main = "src/index.ts"\\n' +
        'compatibility_date = "2026-05-23"\\n' +
        'compatibility_flags = ["nodejs_compat"]\\n\\n' +
        '[[d1_databases]]\\n' +
        'binding = "DB"\\n' +
        'database_name = "' + dbName + '"\\n' +
        'database_id = "' + dbId + '"\\n\\n' +
        '[vars]\\n' +
        'BETTER_AUTH_URL = "' + baseUrl + '"\\n\\n' +
        '# Run: wrangler secret put BETTER_AUTH_SECRET';

      const blob = new Blob([toml], { type: 'application/toml' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'wrangler.toml';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

      showStep(5);
    });

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  })();
</script>
