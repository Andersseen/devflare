# Better Auth Configuration
BETTER_AUTH_SECRET=your-super-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:8787

# Cookie domain for cross-subdomain sessions (production only)
# COOKIE_DOMAIN=.yourdomain.com

# CORS origins (comma-separated, production only)
# DEV_AUTH_CORS_ORIGINS=https://app.yourdomain.com

# Environment identifier
ENVIRONMENT=development
