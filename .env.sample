# =============================================================================
# DevFlare — Environment Variables Sample
# Copy this file to .env and fill in your real values.
# =============================================================================

# ------------------------------------------------------------------------------
# 1. BETTER AUTH (Required for both dev-auth and devflare)
# ------------------------------------------------------------------------------

# Generate a strong random secret (64+ chars recommended):
#   openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Base URL of the auth service
#   Development: http://localhost:8787
#   Staging:     https://auth-staging.yourdomain.com
#   Production:  https://auth.yourdomain.com
BETTER_AUTH_URL=http://localhost:8787

# ------------------------------------------------------------------------------
# 2. COOKIES & CORS (Required for cross-domain in staging/production)
# ------------------------------------------------------------------------------

# Root domain for cross-subdomain cookies
#   Example: .yourdomain.com (note the leading dot)
COOKIE_DOMAIN=

# Allowed origins for CORS (comma-separated, NO wildcards in production!)
#   Example: https://app.yourdomain.com,https://admin.yourdomain.com
DEV_AUTH_CORS_ORIGINS=http://localhost:4200

# ------------------------------------------------------------------------------
# 3. CLOUDFLARE (Required for deploy and D1/KV operations)
# ------------------------------------------------------------------------------

# Get yours from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Cloudflare Workers Edit, D1 Edit, KV Edit
CLOUDFLARE_API_TOKEN=

# Your Cloudflare Account ID (from the right sidebar in Cloudflare dashboard)
CLOUDFLARE_ACCOUNT_ID=

# ------------------------------------------------------------------------------
# 4. GITHUB OAUTH (Optional — only if you want GitHub login)
# ------------------------------------------------------------------------------

# Create a GitHub OAuth App: https://github.com/settings/applications/new
# Authorization callback URL must be:
#   https://auth.yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# 5. SENTRY ERROR TRACKING (Optional but recommended for production)
# ------------------------------------------------------------------------------

# Create a project at https://sentry.io and copy the DSN
SENTRY_DSN=

# Frontend Sentry DSN (can be the same project or a separate one)
VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# 6. ADMIN / BACKUP (Optional — required for admin endpoints)
# ------------------------------------------------------------------------------

# Secret token for protected admin endpoints (/api/admin/*)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# ------------------------------------------------------------------------------
# 7. EMAIL PROVIDER (Optional — required for email verification in production)
# ------------------------------------------------------------------------------

# We recommend Resend: https://resend.com
RESEND_API_KEY=

# ------------------------------------------------------------------------------
# 8. FRONTEND CONFIG
# ------------------------------------------------------------------------------

# URL of the auth service that the frontend will use
#   Development: http://localhost:8787
#   Production:  https://auth.yourdomain.com
DEV_AUTH_URL=http://localhost:8787

# ------------------------------------------------------------------------------
# 9. ENVIRONMENT FLAG
# ------------------------------------------------------------------------------

# Controls production-only behaviors (disables setup, stricter CORS, etc.)
#   development | staging | production
ENVIRONMENT=development
